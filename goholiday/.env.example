# Copy to .env.local and fill in real keys when you wire up live APIs.
# All vars are optional — the app currently runs on deterministic mock data.

# --- Stays / hotels ---
# Booking.com partner program (https://partners.booking.com)
BOOKING_AFFILIATE_ID=
# RapidAPI key for Booking-com / Hotels-com / Airbnb scraper endpoints
RAPIDAPI_KEY=
# Liteapi (https://liteapi.travel) — direct hotel inventory + booking
LITEAPI_KEY=

# --- Flights ---
# Skyscanner partner ID (https://www.partners.skyscanner.net)
SKYSCANNER_PARTNER_ID=
# Amadeus self-service (https://developers.amadeus.com)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
# Duffel (https://duffel.com)
DUFFEL_ACCESS_TOKEN=

# --- Misc ---
# Public site URL used in metadata / canonical
NEXT_PUBLIC_SITE_URL=https://goholiday.example.com
