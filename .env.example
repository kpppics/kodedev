# =============================================================
# CV Tailor AI - Environment Variables
# Copy this file to `.env.local` for local development
# and set these values in the Vercel dashboard for production.
# =============================================================

# ---- Anthropic Claude API ----
# Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Stripe ----
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Resend (transactional email) ----
# Get an API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The "from" address used when emailing CVs. Must be a verified domain in Resend.
RESEND_FROM_EMAIL="CV Tailor AI <cv@yourdomain.com>"

# ---- App URL ----
# Used for Stripe Checkout success/cancel redirects.
# Local: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
