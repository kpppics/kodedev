# ==========================================
# Promptcraft Academy — Backend Environment
# ==========================================

# Server
PORT=3001

# PostgreSQL
DATABASE_URL=postgresql://localhost:5432/promptcraft

# Auth
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# AI Providers (server-side, never expose to client)
CLAUDE_API_KEY=your-claude-api-key
GROQ_API_KEY=your-groq-api-key

# AI Routing
# Primary provider: "claude" or "groq"
AI_PRIMARY_PROVIDER=groq
# Strategy: "primary" | "fallback" | "cheapest" | "fastest"
AI_STRATEGY=fallback

# Content safety
CHILD_SAFE_MODE=true

# Stripe (optional – subscription features)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_JUNIOR_PRICE_ID=price_junior
STRIPE_FAMILY_PRICE_ID=price_family
STRIPE_CLASSROOM_PRICE_ID=price_classroom

# Frontend URL (for CORS + Stripe redirects)
FRONTEND_URL=http://localhost:3000
