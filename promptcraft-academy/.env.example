# ==========================================
# PROMPTCRAFT ACADEMY — Environment Variables
# Copy to .env and fill in your keys
# ==========================================

# Backend API
EXPO_PUBLIC_API_URL=http://localhost:3001/api

# AI Providers — add at least one
# Claude (claude-haiku-4-5 — fast + great quality)
EXPO_PUBLIC_CLAUDE_API_KEY=

# Groq (llama3-8b-8192 — very fast, free tier available)
EXPO_PUBLIC_GROQ_API_KEY=

# AI routing strategy: primary | fallback | cheapest | fastest
# fallback = try primary first, fall back to secondary if it fails
EXPO_PUBLIC_AI_STRATEGY=fallback
